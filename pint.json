{
    "preset": "laravel",
    "rules": {
        "concat_space": {
            "spacing": "one"
        },
        "trailing_comma_in_multiline": true,
        "new_with_braces": true,
        "not_operator_with_successor_space": false,
        "php_unit_method_casing": {
            "case": "snake_case"
        }
    },
    "exclude": ["storage", "bootstrap/cache", "node_modules"]
}
